{
  "id": "engineering",
  "name": "Engineering/IP Pattern Pack",
  "description": "Detection patterns for source code and intellectual property",
  "version": "1.0.0",
  "domain": "engineering",
  "requiredLicenseFeature": "engineering",
  "lastUpdated": "2025-01-08T00:00:00Z",
  "patterns": [
    {
      "id": "eng-001",
      "name": "API Keys",
      "description": "API keys and secrets",
      "category": "engineering",
      "severity": "critical",
      "regulatoryBasis": "Security Best Practices",
      "type": "regex",
      "config": {
        "regex": "(api[_-]?key|secret[_-]?key|access[_-]?token)['\"]?\\s*[:=]\\s*['\"]?[a-zA-Z0-9_-]{20,}",
        "caseSensitive": false
      },
      "enabled": true
    },
    {
      "id": "eng-002",
      "name": "Source Code",
      "description": "Proprietary source code",
      "category": "engineering",
      "severity": "high",
      "regulatoryBasis": "Trade Secret Protection",
      "type": "keyword",
      "config": {
        "keywords": ["proprietary algorithm", "confidential source code", "trade secret"],
        "caseSensitive": false,
        "wholeWord": false
      },
      "enabled": true
    },
    {
      "id": "eng-003",
      "name": "Patent Information",
      "description": "Patent applications and disclosures",
      "category": "engineering",
      "severity": "high",
      "regulatoryBasis": "Patent Law",
      "type": "keyword",
      "config": {
        "keywords": ["patent application", "invention disclosure", "patentable invention"],
        "caseSensitive": false,
        "wholeWord": false
      },
      "enabled": true
    }
  ]
}