{
  "$schema": "./forbidden-words.schema.json",
  "description": "Words that must NEVER appear in user-facing explanations",
  "categories": {
    "alarming": {
      "description": "Alarming language that causes unnecessary anxiety",
      "words": [
        "breach",
        "violation",
        "illegal",
        "leak",
        "incident",
        "attack",
        "threat",
        "danger",
        "emergency",
        "alert"
      ]
    },
    "technical": {
      "description": "Technical/internal implementation terms",
      "words": [
        "icd",
        "ontology",
        "anchor",
        "heuristic",
        "regex",
        "algorithm",
        "proximity",
        "cluster"
      ]
    },
    "dlpStyle": {
      "description": "DLP-style blocking language (we are NOT DLP)",
      "words": [
        "block",
        "prevent",
        "deny",
        "quarantine",
        "intercept"
      ]
    }
  }
}
