{
  "$schema": "./signal-patterns.schema.json",
  "description": "Signal ID patterns for frame selection logic",
  "regulatedPatterns": {
    "description": "Patterns indicating regulated/clinical content (for FRAME_REGULATED_SENSITIVE). Excludes confidentiality markers (distribution signals).",
    "patterns": [
      "coa-",
      "icd",
      "clinical",
      "registry-",
      "pii.",
      "financial."
    ]
  },
  "distributionPatterns": {
    "description": "Patterns indicating distribution restrictions (not content sensitivity). These markers indicate HOW to share, not WHAT the document contains.",
    "patterns": [
      "global-confidential-en",
      "global-confidential-de",
      "global-confidential-fr",
      "global-confidential-es",
      "global-confidential-nordic",
      "english-gov-clearance",
      "romance-confidential",
      "nordic-confidential"
    ]
  },
  "secretsPatterns": {
    "description": "Patterns indicating actual secrets/credentials (content sensitivity, NOT distribution). These remain high/critical severity.",
    "patterns": [
      "global-api-key",
      "global-bearer-token",
      "global-aws-access-key",
      "global-password",
      "global-private-key",
      "global-connection-string",
      "global-url-credentials",
      "global-ma-terms"
    ]
  },
  "businessSensitivePatterns": {
    "description": "Patterns indicating business-sensitive / M&A content (for FRAME_BUSINESS_SENSITIVE). Material non-public information.",
    "patterns": [
      "global-ma-terms",
      "global-ma-valuation"
    ]
  },
  "legalPatterns": {
    "description": "Patterns indicating legal content (for FRAME_LEGAL)",
    "patterns": [
      "legal.",
      "contract",
      "nda",
      "agreement",
      "privileged"
    ]
  },
  "signalFamilies": {
    "description": "Signal family definitions for composite headline generation. Surface language uses human-readable family labels, not internal categories.",
    "families": [
      {
        "id": "medical",
        "label": "medical",
        "patterns": [
          "medical",
          "health",
          "clinical",
          "icd",
          "coa-",
          "patient",
          "diagnosis",
          "prescription"
        ]
      },
      {
        "id": "legal",
        "label": "legal",
        "patterns": [
          "legal.",
          "contract",
          "nda",
          "agreement",
          "privileged",
          "attorney",
          "litigation"
        ]
      },
      {
        "id": "financial",
        "label": "financial",
        "patterns": [
          "financial.",
          "banking",
          "iban",
          "credit_card",
          "payment",
          "invoice",
          "salary",
          "compensation"
        ]
      },
      {
        "id": "personal",
        "label": "personal",
        "patterns": [
          "pii.",
          "ssn",
          "national_id",
          "phone",
          "email",
          "address",
          "dob",
          "employee"
        ]
      },
      {
        "id": "hr",
        "label": "HR",
        "patterns": [
          "hr.",
          "employee",
          "payroll",
          "benefits",
          "performance",
          "termination"
        ]
      },
      {
        "id": "secrets",
        "label": "credentials",
        "patterns": [
          "secret.",
          "api_key",
          "password",
          "private_key",
          "bearer_token",
          "connection_string"
        ]
      }
    ]
  }
}
