{
  "name": "ainotice",
  "version": "1.0.1",
  "description": "Enterprise-grade risk awareness for AI tool uploads",
  "type": "module",
  "scripts": {
    "dev": "npm run build:chrome && npm run build:background:chrome -- --watch",
    "build:content:chrome": "cross-env BUILD_TARGET=chrome vite build --config vite.content.config.ts",
    "build:content:firefox": "cross-env BUILD_TARGET=firefox vite build --config vite.content.config.ts",
    "build:background:chrome": "cross-env BUILD_TARGET=chrome vite build --config vite.background.config.ts",
    "build:background:firefox": "cross-env BUILD_TARGET=firefox vite build --config vite.background.config.ts",
    "build": "npm run build:chrome",
    "build:chrome": "npm run build:content:chrome && npm run build:background:chrome && npx tsx scripts/copy-manifest.ts chrome && npx tsx scripts/test-chrome-build-artifacts.ts && npx tsx scripts/test-consumer-modal-no-admin-license-copy.ts",
    "build:firefox": "npm run build:content:firefox && npm run build:background:firefox && npx tsx scripts/copy-manifest.ts firefox && npx tsx scripts/test-firefox-build-artifacts.ts",
    "build:all": "npm run build:chrome && npm run build:firefox",
    "verify:manifest": "npx tsx scripts/verify-manifest.ts",
    "verify:dist": "npx tsx scripts/verify-dist-targets.ts",
    "test:smoke": "npx tsx scripts/test-all.ts --tier smoke",
    "test": "npx tsx scripts/test-all.ts --tier core",
    "test:full": "npx tsx scripts/test-all.ts --tier full",
    "docpack": "npx tsx scripts/test-doc-pack.ts --mode dev",
    "docpack:strict": "npx tsx scripts/test-doc-pack.ts --mode strict",
    "dashboard": "npx tsx scripts/gen-dashboard-latest.ts",
    "prune:runs": "npx tsx scripts/prune-run-artifacts.ts --keep 3",
    "test:url-creds": "npx tsx scripts/test-url-credential-quality.ts && npx tsx scripts/test-url-creds-integration.ts",
    "test:surface-confidence": "npx tsx scripts/test-surface-confidence.ts",
    "test:data2": "npx tsx scripts/test-data2-semantic-regression.ts",
    "forensics": "npx tsx scripts/forensics/analyze-test-files.ts",
    "test:forensics": "npx tsx scripts/forensics/test-forensics-determinism.ts",
    "test:ui-parity": "npx tsx scripts/test-ui-parity.ts",
    "test:build-artifacts": "npx tsx scripts/test-firefox-build-artifacts.ts",
    "test:icon-integrity": "npx tsx scripts/test-extension-icon-integrity.ts",
    "firefox:manifest:prove": "npx tsx scripts/copy-manifest.ts firefox",
    "clean": "rimraf dist",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx",
    "type-check": "tsc --noEmit",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "npx playwright test --config playwright.config.smoke.ts",
    "test:e2e:firefox": "npx playwright test --config playwright.config.firefox.ts",
    "test:stress": "npx tsx scripts/test-large-file-stress.ts",
    "test:stress:update-report": "npx tsx scripts/test-large-file-stress.ts --update-report",
    "test:benchmark": "npx tsx scripts/run-detection-benchmark.ts",
    "test:corpus": "npx tsx scripts/run-corpus-harness.ts",
    "test:corpus:docx": "npx tsx scripts/run-corpus-harness.ts --only docx",
    "test:corpus:xlsx": "npx tsx scripts/run-corpus-harness.ts --only xlsx",
    "test:corpus:pdf": "npx tsx scripts/run-corpus-harness.ts --only pdf",
    "test:corpus:validate": "npx tsx scripts/test-corpus-validate.ts",
    "test:gold": "npx tsx scripts/run-gold-harness.ts",
    "test:gold:update-baseline": "npx tsx scripts/run-gold-harness.ts --update-baseline",
    "test:clipboard": "npx tsx scripts/run-clipboard-harness.ts",
    "test:clipboard:strict": "npx tsx scripts/run-clipboard-harness.ts --mode strict",
    "test:clipboard:update-report": "npx tsx scripts/run-clipboard-harness.ts --update-report",
    "test:metamorphic": "npx tsx scripts/run-metamorphic-harness.ts",
    "test:consistency": "npx tsx scripts/test-taxonomy-consistency.ts",
    "test:consistency:update-report": "npx tsx scripts/test-taxonomy-consistency.ts --update-report",
    "compile:evidence": "npx tsx scripts/compile-evidence.ts",
    "publish:evidence": "npx tsx scripts/publish-from-evidence.ts",
    "test:adversarial": "npx tsx scripts/generate-adversarial-corpus.ts",
    "gov:deadcode": "npx knip",
    "gov:boundaries": "npx depcruise src --config .dependency-cruiser.cjs --output-type text",
    "gov:sinks": "npx tsx scripts/gov-sink-scan.ts",
    "gov:manifest": "npx tsx scripts/gov-manifest-drift.ts",
    "gov:manifest:update": "npx tsx scripts/gov-manifest-drift.ts --update",
    "gov:traceability": "npx tsx scripts/gov-traceability.ts",
    "gov:all": "npx tsx scripts/gov-all.ts",
    "package:chrome": "npx tsx scripts/package-chrome.ts"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.0.268",
    "@types/jsdom": "^27.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/webextension-polyfill": "^0.10.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^7.0.3",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^8.0.0",
    "geckodriver": "^6.1.0",
    "jsdom": "^27.4.0",
    "knip": "^5.85.0",
    "rimraf": "^5.0.0",
    "selenium-webdriver": "^4.44.0",
    "terser": "^5.31.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-static-copy": "^1.0.0"
  }
}
